{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "User order information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "shippingDetails": { 
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "address1": { "type": "string" },
            "pincode": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" }
          },
          "required": ["name", "email", "address1", "pincode", "city", "state"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A product saved to a user's wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "productPrice": { "type": "number" },
        "productImage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "productName", "productPrice", "productImage", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/wishlists/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User wishlist items"
    }
  }
}
